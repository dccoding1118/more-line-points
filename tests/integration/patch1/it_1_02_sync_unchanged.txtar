# IT-1-02: Second Sync - No Changes
# Scenario: Running sync twice with same API response should detect no changes.

# 1. First sync to populate DB
mock-api $ROOT_DIR/tests/fixture/api/api_page1.json
exec scheduler sync --config $ROOT_DIR/tests/fixture/config/config.yaml
stderr 'Changes detected and updated'

# 2. Second sync with SAME API response
mock-api $ROOT_DIR/tests/fixture/api/api_page1.json
exec scheduler sync --config $ROOT_DIR/tests/fixture/config/config.yaml
stderr 'No changes detected'

