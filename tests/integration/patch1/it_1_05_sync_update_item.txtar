# IT-1-05: Sync - Update Existing Activity (L2)
# Scenario: An existing activity has a title change, DB should be updated.

# 1. Initial state
exec scheduler init --config $ROOT_DIR/tests/fixture/config/config.yaml
db-insert $ROOT_DIR/tests/fixture/db/seed_A.sql

# 2. Sync with updated A
mock-api $ROOT_DIR/tests/fixture/api/api_A_updated.json
exec scheduler sync --config $ROOT_DIR/tests/fixture/config/config.yaml
stderr 'Changes detected and updated'

# 3. Verify title is updated
db-query 'SELECT title FROM activities WHERE id = "ACT-A"'
stdout 'Updated Title A'

